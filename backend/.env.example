# Copy this file to .env and fill in real values. Never commit .env.

PORT=3000

# Comma-separated list of origins allowed to call this API (the live site +
# localhost for testing the static frontend on your machine).
ALLOWED_ORIGINS=https://muxammadxon202.github.io,http://localhost:8088

# --- Telegram ---
# Create a bot with @BotFather, get the token, then message your bot once
# and call https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
# (or add the bot to a group and use the group's chat_id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Mir Orexov Website <no-reply@mirorexov.uz>
EMAIL_TO=info@mirorexov.uz

# --- Google Sheets ---
# Service account JSON (the whole file content, as one line) for a Google
# Cloud service account with the Sheets API enabled. Share the target sheet
# with the service account's email (client_email field in the JSON) as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Leads!A:I
